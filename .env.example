# =============================================================================
# The Principals Club — Accountability Platform · Environment
# Copy this file to .env.local and fill in the values you have.
# Every integration is optional: when a key is absent the app falls back to a
# clearly-marked demo stub so the product remains fully navigable.
# =============================================================================

# ---- Supabase (required for auth, database, realtime, storage) ----
NEXT_PUBLIC_SUPABASE_URL=
# Client key. Use the newer publishable key (sb_publishable_…) OR the legacy
# anon key — either works. Provide one of the two.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server only, NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Site ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to "true" to keep the demo "bypass — tour the House" button available even
# when Supabase is configured. The tour serves furnished dummy data, not real
# records. Leave unset/false in production.
NEXT_PUBLIC_ENABLE_PREVIEW=

# ---- Daily.co (video) ----
DAILY_API_KEY=
NEXT_PUBLIC_DAILY_DOMAIN=

# ---- Deepgram (transcription) ----
DEEPGRAM_API_KEY=

# ---- OpenAI (transcript -> goals extraction) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Google Calendar (OAuth) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/google/callback

# ---- Microsoft Graph / Outlook Calendar (OAuth) ----
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/calendar/microsoft/callback
